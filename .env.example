# ── Auth ──────────────────────────────────────────────────────────────────────
# Required. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
FACTORY_API_KEY=

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Voice ─────────────────────────────────────────────────────────────────────
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8391
DEBUG=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated. Empty = no cross-origin access.
ALLOWED_ORIGINS=

# ── Rate limits (per API key, per hour) ───────────────────────────────────────
RATE_LIMIT_SESSIONS_PER_HOUR=20
RATE_LIMIT_SUBMITS_PER_HOUR=100

# ── Session behaviour ─────────────────────────────────────────────────────────
PROBE_LIMIT=3
MAX_STAGE_N=20

# ── Digital Ocean Spaces ──────────────────────────────────────────────────────
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=lon1
DO_SPACES_BUCKET=connectionsphere-factory

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
JSON_LOGS=false
